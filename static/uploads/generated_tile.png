<section class="admin-login-bg">

    
<div class="container mt-4 mb-5">
<div class="card p-4 shadow">

    <div class="text-center mb-3">
        <h4 class="fw-bold" style="color:#4f46e5;">&#127912; Tile Design Studio</h4>
        <p class="text-muted mb-0" style="font-size:0.9rem;">Draw anything - AI will recognize, suggest improvements, and generate a realistic tile image</p>
    </div>

    <div class="mb-3 p-3" style="background:#f8fafc;border-radius:10px;border:1px solid #e2e8f0;">
        <label class="toolbar-label d-block mb-2">Upload White Tile (Optional)</label>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <input type="file" name="ctl00$ContentPlaceHolder1$FileUpload1" id="ContentPlaceHolder1_FileUpload1" class="form-control" style="max-width:300px;" />
            <input type="submit" name="ctl00$ContentPlaceHolder1$ButtonLoad" value="Load Image" id="ContentPlaceHolder1_ButtonLoad" class="btn btn-secondary btn-sm" />
        </div>
    </div>

    <div class="p-3 mb-3" style="background:#f8fafc;border-radius:10px;border:1px solid #e2e8f0;">
        <div class="mb-2">
            <span class="toolbar-label">Color</span>
            <div class="mt-1" id="colorSwatches">
                <div class="color-box active" style="background:#e11d48" onclick="changeColor('#e11d48',this)"></div>
                <div class="color-box" style="background:#2563eb" onclick="changeColor('#2563eb',this)"></div>
                <div class="color-box" style="background:#16a34a" onclick="changeColor('#16a34a',this)"></div>
                <div class="color-box" style="background:#0f172a" onclick="changeColor('#0f172a',this)"></div>
                <div class="color-box" style="background:#ca8a04" onclick="changeColor('#ca8a04',this)"></div>
                <div class="color-box" style="background:#ea580c" onclick="changeColor('#ea580c',this)"></div>
                <div class="color-box" style="background:#7c3aed" onclick="changeColor('#7c3aed',this)"></div>
                <div class="color-box" style="background:#0891b2" onclick="changeColor('#0891b2',this)"></div>
                <div class="color-box" style="background:#db2777" onclick="changeColor('#db2777',this)"></div>
                <div class="color-box" style="background:#65a30d" onclick="changeColor('#65a30d',this)"></div>
                <div class="color-box" style="background:#ffffff;border:2px solid #cbd5e1;" onclick="changeColor('#ffffff',this)"></div>
                <input type="color" id="colorPicker" value="#e11d48"
                    onchange="changeColor(this.value,null)"
                    style="width:34px;height:34px;border:none;cursor:pointer;border-radius:50%;vertical-align:middle;margin:2px;" />
            </div>
        </div>
        <hr class="section-divider" />
        <div class="mb-2">
            <span class="toolbar-label">Draw Tool</span>
            <div class="mt-1 d-flex flex-wrap gap-1">
                <button type="button" class="tool-btn active" id="btnDraw"     onclick="setTool('draw')">Brush</button>
                <button type="button" class="tool-btn"        id="btnErase"    onclick="setTool('erase')">Erase</button>
                <button type="button" class="tool-btn"        id="btnLine"     onclick="setTool('line')">Line</button>
                <button type="button" class="tool-btn"        id="btnRect"     onclick="setTool('rect')">Rectangle</button>
                <button type="button" class="tool-btn"        id="btnCircle"   onclick="setTool('circle')">Circle</button>
                <button type="button" class="tool-btn"        id="btnTriangle" onclick="setTool('triangle')">Triangle</button>
                <button type="button" class="tool-btn"        id="btnStar"     onclick="setTool('star')">Star</button>
                <button type="button" class="tool-btn"        id="btnDiamond"  onclick="setTool('diamond')">Diamond</button>
                <button type="button" class="tool-btn"        id="btnArrow"    onclick="setTool('arrow')">Arrow</button>
                <label style="display:inline-flex;align-items:center;gap:5px;font-size:0.82rem;color:#334155;cursor:pointer;margin-left:6px;">
                    <input type="checkbox" id="chkFill" /> Fill Shape
                </label>
            </div>
        </div>
        <hr class="section-divider" />
        <div>
            <span class="toolbar-label">Brush / Border Size</span>
            <div class="d-flex align-items-center gap-2 mt-1">
                <input type="range" id="brushSize" min="1" max="30" value="3"
                    style="width:110px;" oninput="updateBrush(this.value)" />
                <span id="brushLabel" class="text-muted" style="font-size:0.85rem;min-width:28px;">3px</span>
            </div>
        </div>
    </div>

    <div class="text-center" style="position:relative;display:inline-block;width:100%;">
        <canvas id="canvas" width="500" height="350"></canvas>
        <canvas id="previewCanvas" width="500" height="350"
            style="position:absolute;top:0;left:50%;transform:translateX(-50%);pointer-events:none;border-radius:10px;"></canvas>
    </div>

    <div class="text-center mt-3 d-flex flex-wrap justify-content-center gap-2">
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="undoLast()">Undo</button>
        <button type="button" class="btn btn-outline-danger btn-sm"    onclick="clearCanvas()">Clear</button>
        <button type="button" class="btn btn-ai"                       onclick="askAI()">&#10024; AI Suggestions</button>
        
        <input type="hidden" name="ctl00$ContentPlaceHolder1$HiddenField1" id="ContentPlaceHolder1_HiddenField1" />
        <input type="hidden" name="ctl00$ContentPlaceHolder1$HiddenField2" id="ContentPlaceHolder1_HiddenField2" />
        <input type="submit" name="ctl00$ContentPlaceHolder1$ButtonSave" value="Save Design" onclick="saveImage();" id="ContentPlaceHolder1_ButtonSave" class="btn btn-success" />
    </div>

    <div id="aiPanel">
        <h5>&#10024; AI Design Suggestions</h5>
        <div id="aiLoader">
            <span class="spinner-dot"></span><span class="spinner-dot"></span><span class="spinner-dot"></span>
            <div class="mt-2" style="font-size:0.9rem;">AI is analyzing your drawing...</div>
        </div>
        <div id="aiResults" style="display:none;">
            <div class="ai-section">
                <h6>AI Recognized</h6>
                <div class="recognition-badge" id="recognitionBadge">-</div>
            </div>
            <div class="ai-section">
                <h6>Design Analysis</h6>
                <p id="analysisText"></p>
            </div>
            <div class="ai-section">
                <h6>Enhancement Suggestions</h6>
                <div id="suggestionsList"></div>
            </div>
            <div class="ai-section">
                <h6>AI Color Palette - click to draw</h6>
                <div id="aiPalette"></div>
            </div>
            <div class="ai-section">
                <h6>Style Direction</h6>
                <span class="style-badge" id="styleText"></span>
            </div>
            <div class="ai-section text-center">
                <h6>Generate Realistic Tile Image</h6>
                <p style="font-size:0.88rem;color:#64748b;margin-bottom:12px;">
                    AI will create a professional realistic tile image based on your drawing and suggestions
                </p>
                <button type="button" class="btn-generate" id="btnGenerate" onclick="generateRealisticImage()">
                    &#127775; Generate Realistic Tile Image
                </button>
            </div>
            <div class="ai-section">
                <h6>Quick Apply Pattern</h6>
                <div class="d-flex gap-1 flex-wrap">
                    <button type="button" class="btn btn-sm btn-outline-primary"   onclick="applyPattern('geometric')">Geometric</button>
                    <button type="button" class="btn btn-sm btn-outline-success"   onclick="applyPattern('floral')">Floral</button>
                    <button type="button" class="btn btn-sm btn-outline-warning"   onclick="applyPattern('abstract')">Abstract</button>
                    <button type="button" class="btn btn-sm btn-outline-danger"    onclick="applyPattern('diagonal')">Diagonal</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="applyPattern('dots')">Dots</button>
                    <button type="button" class="btn btn-sm btn-outline-info"      onclick="applyPattern('zigzag')">Zigzag</button>
                    <button type="button" class="btn btn-sm btn-outline-dark"      onclick="applyPattern('mandala')">Mandala</button>
                    <button type="button" class="btn btn-sm btn-outline-primary"   onclick="applyPattern('hexagon')">Hexagon</button>
                    <button type="button" class="btn btn-sm btn-outline-success"   onclick="applyPattern('waves')">Waves</button>
                    <button type="button" class="btn btn-sm btn-outline-warning"   onclick="applyPattern('checkerboard')">Checkerboard</button>
                    <button type="button" class="btn btn-sm btn-outline-danger"    onclick="applyPattern('stars')">Stars</button>
                    <button type="button" class="btn btn-sm btn-outline-info"      onclick="applyPattern('diamonds')">Diamonds</button>
                    <button type="button" class="btn btn-sm btn-outline-dark"      onclick="applyPattern('crosshatch')">Crosshatch</button>
                    <button type="button" class="btn btn-sm btn-outline-primary"   onclick="applyPattern('spiral')">Spiral</button>
                    <button type="button" class="btn btn-sm btn-outline-success"   onclick="applyPattern('triangles')">Triangles</button>
                    <button type="button" class="btn btn-sm btn-outline-warning"   onclick="applyPattern('moroccan')">Moroccan</button>
                </div>
            </div>
        </div>
    </div>

    <div id="generatedSection" style="display:none;">
        <h5>&#127775; AI Generated Realistic Tile</h5>
        <div id="genLoader">
            <span class="gen-spinner"></span><span class="gen-spinner"></span><span class="gen-spinner"></span>
            <div class="mt-2" style="font-size:0.9rem;color:#059669;">Generating your realistic tile image... this may take 20-30 seconds</div>
        </div>
        <div id="generatedImageBox" style="display:none;">
            <img id="generatedImg" src="" alt="Generated Tile" />
            <div class="mt-3">
                <span id="savedBadge">&#10003; Saved to your account</span>
            </div>
            <div class="mt-2">
                <a id="downloadLink" href="#" download="generated_tile.png"
                    class="btn btn-sm btn-outline-success">&#8681; Download Image</a>
            </div>
        </div>
    </div>

</div>
</div>

<script type="text/javascript">
var canvas        = document.getElementById("canvas");
var previewCanvas = document.getElementById("previewCanvas");
var ctx           = canvas.getContext("2d");
var pctx          = previewCanvas.getContext("2d");
var drawing       = false;
var selectedColor = "#e11d48";
var brushSize     = 3;
var currentTool   = "draw";
var snapshots     = [];
var startX = 0, startY = 0;

var aiSuggestionsText  = "";
var aiRecognizedObject = "";
var aiStyleName        = "";

ctx.fillStyle = "#ffffff";
ctx.fillRect(0, 0, canvas.width, canvas.height);
snapshots.push(canvas.toDataURL());

function changeColor(color, el) {
    selectedColor = color;
    if (currentTool === 'erase') setTool('draw');
    var boxes = document.querySelectorAll('.color-box');
    for (var i = 0; i < boxes.length; i++) boxes[i].classList.remove('active');
    if (el) el.classList.add('active');
    if (color.indexOf('#') === 0) document.getElementById('colorPicker').value = color;
}
function updateBrush(val) {
    brushSize = parseInt(val);
    document.getElementById('brushLabel').textContent = val + 'px';
}
function setTool(tool) {
    currentTool = tool;
    var tools = ['btnDraw','btnErase','btnLine','btnRect','btnCircle','btnTriangle','btnStar','btnDiamond','btnArrow'];
    for (var i = 0; i < tools.length; i++) document.getElementById(tools[i]).classList.remove('active');
    var map = { draw:'btnDraw',erase:'btnErase',line:'btnLine',rect:'btnRect',circle:'btnCircle',triangle:'btnTriangle',star:'btnStar',diamond:'btnDiamond',arrow:'btnArrow' };
    if (map[tool]) document.getElementById(map[tool]).classList.add('active');
}
function loadBackground(imgUrl) {
    var img = new Image();
    img.onload = function() {
        ctx.clearRect(0,0,canvas.width,canvas.height);
        ctx.fillStyle="#ffffff"; ctx.fillRect(0,0,canvas.width,canvas.height);
        ctx.drawImage(img,0,0,canvas.width,canvas.height);
        snapshots=[canvas.toDataURL()];
    };
    img.src = imgUrl;
}

canvas.onmousedown = function(e) {
    drawing=true; startX=e.offsetX; startY=e.offsetY;
    if (currentTool==='draw'||currentTool==='erase') { saveSnapshot(); ctx.beginPath(); ctx.moveTo(startX,startY); }
};
canvas.onmouseup = function(e) {
    if (!drawing) return; drawing=false;
    if (currentTool!=='draw'&&currentTool!=='erase') {
        saveSnapshot(); pctx.clearRect(0,0,previewCanvas.width,previewCanvas.height);
        drawShape(ctx,startX,startY,e.offsetX,e.offsetY,currentTool,false);
    }
    ctx.beginPath();
};
canvas.onmouseleave = function() { drawing=false; ctx.beginPath(); pctx.clearRect(0,0,previewCanvas.width,previewCanvas.height); };
canvas.onmousemove = function(e) {
    if (!drawing) return;
    if (currentTool==='draw'||currentTool==='erase') {
        ctx.lineWidth=(currentTool==='erase')?brushSize*3:brushSize;
        ctx.lineCap="round"; ctx.lineJoin="round";
        ctx.strokeStyle=(currentTool==='erase')?"#ffffff":selectedColor;
        ctx.lineTo(e.offsetX,e.offsetY); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(e.offsetX,e.offsetY);
    } else {
        pctx.clearRect(0,0,previewCanvas.width,previewCanvas.height);
        drawShape(pctx,startX,startY,e.offsetX,e.offsetY,currentTool,true);
    }
};

canvas.addEventListener('touchstart',function(e){
    e.preventDefault(); var rect=canvas.getBoundingClientRect();
    startX=e.touches[0].clientX-rect.left; startY=e.touches[0].clientY-rect.top;
    drawing=true;
    if(currentTool==='draw'||currentTool==='erase'){saveSnapshot();ctx.beginPath();ctx.moveTo(startX,startY);}
},{passive:false});
canvas.addEventListener('touchmove',function(e){
    e.preventDefault(); var rect=canvas.getBoundingClientRect();
    var tx=e.touches[0].clientX-rect.left, ty=e.touches[0].clientY-rect.top;
    if(currentTool==='draw'||currentTool==='erase'){
        ctx.lineWidth=(currentTool==='erase')?brushSize*3:brushSize;
        ctx.lineCap="round";ctx.lineJoin="round";
        ctx.strokeStyle=(currentTool==='erase')?"#ffffff":selectedColor;
        ctx.lineTo(tx,ty);ctx.stroke();ctx.beginPath();ctx.moveTo(tx,ty);
    } else {
        pctx.clearRect(0,0,previewCanvas.width,previewCanvas.height);
        drawShape(pctx,startX,startY,tx,ty,currentTool,true);
    }
},{passive:false});
canvas.addEventListener('touchend',function(e){
    if(!drawing) return; drawing=false;
    if(currentTool!=='draw'&&currentTool!=='erase'){
        var rect=canvas.getBoundingClientRect();
        var tx=e.changedTouches[0].clientX-rect.left, ty=e.changedTouches[0].clientY-rect.top;
        saveSnapshot(); pctx.clearRect(0,0,previewCanvas.width,previewCanvas.height);
        drawShape(ctx,startX,startY,tx,ty,currentTool,false);
    }
    ctx.beginPath();
});

function drawShape(c,x1,y1,x2,y2,type,isPreview){
    var fill=document.getElementById('chkFill').checked;
    c.save(); c.globalAlpha=isPreview?0.6:1.0;
    c.strokeStyle=selectedColor; c.fillStyle=selectedColor;
    c.lineWidth=brushSize; c.lineCap="round"; c.lineJoin="round";
    var w=x2-x1,h=y2-y1,cx=(x1+x2)/2,cy=(y1+y2)/2;
    var rx=Math.abs(w)/2,ry=Math.abs(h)/2;
    var r=Math.sqrt(w*w+h*h)/2;
    c.beginPath();
    if(type==='line'){c.moveTo(x1,y1);c.lineTo(x2,y2);c.stroke();}
    else if(type==='rect'){c.rect(x1,y1,w,h);if(fill)c.fill();else c.stroke();}
    else if(type==='circle'){c.ellipse(cx,cy,rx,ry,0,0,Math.PI*2);if(fill)c.fill();else c.stroke();}
    else if(type==='triangle'){c.moveTo(cx,y1);c.lineTo(x2,y2);c.lineTo(x1,y2);c.closePath();if(fill)c.fill();else c.stroke();}
    else if(type==='star'){
        var oR=r,iR=r*0.45,pts=5;
        for(var i=0;i<pts*2;i++){var a=(i*Math.PI/pts)-Math.PI/2,rd=(i%2===0)?oR:iR;
            if(i===0)c.moveTo(cx+rd*Math.cos(a),cy+rd*Math.sin(a));else c.lineTo(cx+rd*Math.cos(a),cy+rd*Math.sin(a));}
        c.closePath();if(fill)c.fill();else c.stroke();
    }
    else if(type==='diamond'){c.moveTo(cx,y1);c.lineTo(x2,cy);c.lineTo(cx,y2);c.lineTo(x1,cy);c.closePath();if(fill)c.fill();else c.stroke();}
    else if(type==='arrow'){
        var hl=Math.max(15,r*0.35),ang=Math.atan2(y2-y1,x2-x1);
        c.moveTo(x1,y1);c.lineTo(x2,y2);c.stroke();c.beginPath();
        c.moveTo(x2,y2);c.lineTo(x2-hl*Math.cos(ang-Math.PI/6),y2-hl*Math.sin(ang-Math.PI/6));
        c.moveTo(x2,y2);c.lineTo(x2-hl*Math.cos(ang+Math.PI/6),y2-hl*Math.sin(ang+Math.PI/6));c.stroke();
    }
    c.restore();
}

function saveSnapshot(){snapshots.push(canvas.toDataURL());if(snapshots.length>40)snapshots.shift();}
function undoLast(){if(!snapshots.length)return;var img=new Image();img.onload=function(){ctx.clearRect(0,0,canvas.width,canvas.height);ctx.drawImage(img,0,0);};img.src=snapshots.pop();}
function clearCanvas(){saveSnapshot();ctx.fillStyle="#ffffff";ctx.fillRect(0,0,canvas.width,canvas.height);}
function saveImage(){document.getElementById('ContentPlaceHolder1_HiddenField1').value=canvas.toDataURL("image/png");}

function askAI() {
    var panel=document.getElementById('aiPanel');
    var loader=document.getElementById('aiLoader');
    var results=document.getElementById('aiResults');
    panel.style.display='block'; loader.style.display='block'; results.style.display='none';
    panel.scrollIntoView({behavior:'smooth',block:'nearest'});
    var imageData=canvas.toDataURL("image/png").split(',')[1];
    fetch("AIDesign.ashx",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({imageData:imageData})})
    .then(function(r){if(!r.ok)throw new Error("Server error: "+r.status);return r.json();})
    .then(function(data){
        loader.style.display='none';
        if(data.error){document.getElementById('recognitionBadge').textContent='Error: '+data.error;results.style.display='block';return;}
        parseAndDisplay(data.result||'');
        results.style.display='block';
    })
    .catch(function(err){loader.style.display='none';document.getElementById('recognitionBadge').textContent='Error: '+err.message;results.style.display='block';});
}

function parseAndDisplay(text) {
    aiSuggestionsText = text;
    var lines=text.split('\n');
    var recognition='';
    for(var i=0;i<lines.length;i++){
        if(lines[i].match(/Drawing Recognition|^\*\*1\./i)){
            var c1=lines[i].replace(/.*Drawing Recognition[^:]*:/i,'').replace(/^\*\*1\.\s*/,'').replace(/\*\*/g,'').trim();
            if(!c1&&lines[i+1])c1=lines[i+1].replace(/\*\*/g,'').trim();
            if(c1){recognition=c1;break;}
        }
    }
    if(!recognition){var bm=text.match(/\*\*([^*\n]+)\*\*/);if(bm)recognition=bm[1];}
    aiRecognizedObject=recognition||'tile design';
    document.getElementById('recognitionBadge').innerHTML=aiRecognizedObject;

    var analysis='';
    for(var i=0;i<lines.length;i++){
        if(lines[i].match(/Design Analysis|^\*\*2\./i)){
            var col=[];
            for(var j=i+1;j<Math.min(i+6,lines.length);j++){
                var l=lines[j].replace(/\*\*/g,'').trim();
                if(l&&!l.match(/^\*\*[0-9]/)&&!l.match(/Enhancement|Color|Style/i))col.push(l);
                else if(col.length)break;
            }
            analysis=col.join(' ');break;
        }
    }
    document.getElementById('analysisText').textContent=analysis;

    var sl=document.getElementById('suggestionsList');sl.innerHTML='';
    var sc=0,inS=false;
    for(var i=0;i<lines.length;i++){
        if(lines[i].match(/Enhancement Suggestions|^\*\*3\./i)){inS=true;continue;}
        if(inS&&lines[i].match(/Color Palette|PALETTE|^\*\*4\./i))break;
        if(inS&&sc<3){
            var l=lines[i].replace(/^[-*•]\s*/,'').replace(/\*\*/g,'').trim();
            if(l&&l.length>10){sc++;sl.innerHTML+='<div class="suggestion-item"><div class="suggestion-num">'+sc+'</div><div>'+l+'</div></div>';}
        }
    }

    var pm=text.match(/PALETTE:\s*(#[0-9a-fA-F]{3,6}(?:,\s*#[0-9a-fA-F]{3,6})*)/i);
    var pd=document.getElementById('aiPalette');pd.innerHTML='';
    if(pm){
        var cols=pm[1].split(',');
        for(var c=0;c<cols.length;c++){(function(hex){
            var chip=document.createElement('span');
            chip.className='palette-chip';chip.style.background=hex;chip.title=hex;
            chip.onclick=function(){selectedColor=hex;setTool('draw');document.getElementById('colorPicker').value=hex;
                var boxes=document.querySelectorAll('.color-box');for(var b=0;b<boxes.length;b++)boxes[b].classList.remove('active');};
            pd.appendChild(chip);
        })(cols[c].trim());}
        var hint=document.createElement('div');hint.style.cssText='font-size:0.8rem;color:#64748b;margin-top:6px;';
        hint.textContent='Click a color to draw with it';pd.appendChild(hint);
    }

    var style='';
    for(var i=0;i<lines.length;i++){
        if(lines[i].match(/Style Direction|^\*\*5\./i)){
            var c2=lines[i].replace(/.*Style Direction[^:]*:/i,'').replace(/^\*\*5\.\s*/,'').replace(/\*\*/g,'').trim();
            if(!c2&&lines[i+1])c2=lines[i+1].replace(/\*\*/g,'').trim();
            if(c2){style=c2;break;}
        }
    }
    aiStyleName=style||'Artisan Tile Design';
    document.getElementById('styleText').textContent=aiStyleName;
}

function generateRealisticImage() {
    var genSection = document.getElementById('generatedSection');
    var genLoader  = document.getElementById('genLoader');
    var genBox     = document.getElementById('generatedImageBox');
    var savedBadge = document.getElementById('savedBadge');
    var btnGen     = document.getElementById('btnGenerate');

    genSection.style.display = 'block';
    genLoader.style.display  = 'block';
    genBox.style.display     = 'none';
    savedBadge.style.display = 'none';
    btnGen.disabled          = true;
    genSection.scrollIntoView({behavior:'smooth', block:'nearest'});

    var prompt =
        "Realistic ceramic tile design, " + aiRecognizedObject + " motif, " +
        aiStyleName + " style, square tile, glazed surface, white background, " +
        "product photography, high resolution";

    fetch("GenerateImage.ashx", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
            prompt:   prompt,
            username: 'viki',
            email:    '24spcs17@tcarts.in'
        })
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
        genLoader.style.display = 'none';
        btnGen.disabled = false;

        if (data.error) {
            genBox.style.display = 'block';
            document.getElementById('generatedImg').src = '';
            document.getElementById('generatedImg').alt = 'Error: ' + data.error;
            return;
        }

        var imgSrc = 'data:image/png;base64,' + data.imageBase64;
        document.getElementById('generatedImg').src = imgSrc;
        document.getElementById('downloadLink').href = imgSrc;

        // ✅ Save AI filename to HiddenField2 so it gets saved with request
        document.getElementById('ContentPlaceHolder1_HiddenField2').value = data.filename;

        genBox.style.display     = 'block';
        savedBadge.style.display = 'inline-block';
    })
    .catch(function(err){
        genLoader.style.display = 'none';
        btnGen.disabled = false;
        genBox.style.display = 'block';
        document.getElementById('generatedImg').alt = 'Error: ' + err.message;
    });
}

function applyPattern(type) {
    saveSnapshot();
    var w=canvas.width,h=canvas.height;
    ctx.save(); ctx.globalAlpha=0.22;
    ctx.strokeStyle=selectedColor; ctx.fillStyle=selectedColor; ctx.lineWidth=1.5;
    if(type==='geometric'){for(var x=0;x<w;x+=50)for(var y=0;y<h;y+=50){ctx.beginPath();ctx.rect(x+5,y+5,40,40);ctx.stroke();ctx.beginPath();ctx.moveTo(x+5,y+5);ctx.lineTo(x+45,y+45);ctx.moveTo(x+45,y+5);ctx.lineTo(x+5,y+45);ctx.stroke();}}
    else if(type==='floral'){for(var x=25;x<w;x+=55)for(var y=25;y<h;y+=55){for(var i=0;i<6;i++){ctx.beginPath();ctx.ellipse(x+Math.cos(i*Math.PI/3)*12,y+Math.sin(i*Math.PI/3)*12,7,3.5,i*Math.PI/3,0,Math.PI*2);ctx.fill();}ctx.beginPath();ctx.arc(x,y,4,0,Math.PI*2);ctx.fill();}}
    else if(type==='abstract'){ctx.lineWidth=2;for(var i=0;i<20;i++){ctx.beginPath();ctx.moveTo(Math.random()*w,Math.random()*h);ctx.bezierCurveTo(Math.random()*w,Math.random()*h,Math.random()*w,Math.random()*h,Math.random()*w,Math.random()*h);ctx.stroke();}}
    else if(type==='diagonal'){for(var i=-h;i<w+h;i+=22){ctx.beginPath();ctx.moveTo(i,0);ctx.lineTo(i+h,h);ctx.stroke();}}
    else if(type==='dots'){for(var x=22;x<w;x+=38)for(var y=22;y<h;y+=38){ctx.beginPath();ctx.arc(x,y,5,0,Math.PI*2);ctx.fill();}}
    else if(type==='zigzag'){ctx.lineWidth=2;for(var row=0;row<8;row++){var y0=row*44+22;ctx.beginPath();ctx.moveTo(0,y0);for(var x=0;x<w;x+=30){ctx.lineTo(x+15,y0-18);ctx.lineTo(x+30,y0);}ctx.stroke();}}
    else if(type==='mandala'){var cx=w/2,cy=h/2;for(var ring=1;ring<=5;ring++){var r=ring*32,petals=ring*6;for(var p=0;p<petals;p++){var ang=(p/petals)*Math.PI*2;ctx.beginPath();ctx.ellipse(cx+Math.cos(ang)*r*0.7,cy+Math.sin(ang)*r*0.7,r*0.18,r*0.09,ang,0,Math.PI*2);ctx.fill();}ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.stroke();}}
    else if(type==='hexagon'){var size=30,hx=size*Math.sqrt(3),hy=size*1.5;for(var col=0;col*hx<w+hx;col++)for(var row=0;row*hy<h+hy;row++){var ox=col*hx+(row%2)*hx/2,oy=row*hy;ctx.beginPath();for(var s=0;s<6;s++){var a=Math.PI/180*(60*s-30);if(s===0)ctx.moveTo(ox+size*Math.cos(a),oy+size*Math.sin(a));else ctx.lineTo(ox+size*Math.cos(a),oy+size*Math.sin(a));}ctx.closePath();ctx.stroke();}}
    else if(type==='waves'){ctx.lineWidth=2;for(var row=0;row<12;row++){var y0=row*30+15;ctx.beginPath();ctx.moveTo(0,y0);for(var x=0;x<w;x+=40)ctx.bezierCurveTo(x+10,y0-15,x+30,y0+15,x+40,y0);ctx.stroke();}}
    else if(type==='checkerboard'){ctx.globalAlpha=0.15;for(var x=0;x<w;x+=40)for(var y=0;y<h;y+=40)if((Math.floor(x/40)+Math.floor(y/40))%2===0)ctx.fillRect(x,y,40,40);}
    else if(type==='stars'){for(var x=35;x<w;x+=60)for(var y=35;y<h;y+=60){ctx.beginPath();for(var s=0;s<10;s++){var a=(s*Math.PI/5)-Math.PI/2,r2=(s%2===0)?18:8;if(s===0)ctx.moveTo(x+r2*Math.cos(a),y+r2*Math.sin(a));else ctx.lineTo(x+r2*Math.cos(a),y+r2*Math.sin(a));}ctx.closePath();ctx.fill();}}
    else if(type==='diamonds'){for(var x=25;x<w;x+=50)for(var y=25;y<h;y+=50){ctx.beginPath();ctx.moveTo(x,y-20);ctx.lineTo(x+20,y);ctx.lineTo(x,y+20);ctx.lineTo(x-20,y);ctx.closePath();ctx.stroke();}}
    else if(type==='crosshatch'){ctx.lineWidth=1;for(var i=0;i<w;i+=20){ctx.beginPath();ctx.moveTo(i,0);ctx.lineTo(i,h);ctx.stroke();}for(var i=0;i<h;i+=20){ctx.beginPath();ctx.moveTo(0,i);ctx.lineTo(w,i);ctx.stroke();}}
    else if(type==='spiral'){var cx=w/2,cy=h/2;ctx.lineWidth=1.5;ctx.beginPath();for(var angle=0;angle<Math.PI*16;angle+=0.05){var r=angle*5,sx=cx+r*Math.cos(angle),sy=cy+r*Math.sin(angle);if(angle===0)ctx.moveTo(sx,sy);else ctx.lineTo(sx,sy);if(r>Math.min(w,h)/2)break;}ctx.stroke();}
    else if(type==='triangles'){for(var x=0;x<w;x+=50)for(var y=0;y<h;y+=44){ctx.beginPath();ctx.moveTo(x+25,y);ctx.lineTo(x+50,y+44);ctx.lineTo(x,y+44);ctx.closePath();ctx.stroke();ctx.beginPath();ctx.moveTo(x+25,y+44);ctx.lineTo(x+50,y);ctx.lineTo(x,y);ctx.closePath();ctx.stroke();}}
    else if(type==='moroccan'){var s=40;for(var x=0;x<w+s;x+=s)for(var y=0;y<h+s;y+=s){ctx.beginPath();ctx.moveTo(x,y-s*0.4);ctx.lineTo(x+s*0.4,y);ctx.lineTo(x,y+s*0.4);ctx.lineTo(x-s*0.4,y);ctx.closePath();ctx.stroke();ctx.beginPath();ctx.arc(x,y,s*0.15,0,Math.PI*2);ctx.fill();}}
    ctx.restore();
}
</script>


</section>

<script src="js/common.js"></script>

</div>

</form>

</body>
