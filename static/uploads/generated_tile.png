<script language="javascript" type="text/javascript">
    function accept(id) { location.href = 'Userpurchase1.aspx?id=' + id; }
</script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&display=swap" rel="stylesheet" />
<style>
    body { font-family: 'Sora', sans-serif; }
    #canvas {
        border: 2px solid #334155; cursor: crosshair;
        border-radius: 10px; box-shadow: 0 4px 24px rgba(0,0,0,0.12);
        background: #fff; max-width: 100%;
    }
    .color-box {
        width: 30px; height: 30px; border-radius: 50%;
        border: 2px solid #fff; box-shadow: 0 0 0 2px #cbd5e1;
        display: inline-block; cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s;
        vertical-align: middle; margin: 2px;
    }
    .color-box:hover  { transform: scale(1.2); box-shadow: 0 0 0 3px #6366f1; }
    .color-box.active { box-shadow: 0 0 0 3px #6366f1; transform: scale(1.15); }
    .tool-btn {
        border: 1.5px solid #cbd5e1; background: #fff;
        border-radius: 8px; padding: 5px 11px;
        font-size: 0.82rem; font-weight: 600;
        cursor: pointer; transition: all 0.15s; color: #334155;
    }
    .tool-btn:hover  { border-color: #6366f1; color: #6366f1; background: #f0f4ff; }
    .tool-btn.active { border-color: #6366f1; background: #6366f1; color: #fff; }
    #aiPanel {
        background: linear-gradient(135deg, #f0f4ff 0%, #faf5ff 100%);
        border: 1.5px solid #c7d2fe; border-radius: 14px;
        padding: 20px; margin-top: 20px; display: none;
    }
    #aiPanel h5 { color: #4f46e5; font-weight: 700; margin-bottom: 14px; }
    .ai-section {
        background: #fff; border: 1px solid #e0e7ff;
        border-radius: 10px; padding: 14px 16px; margin-bottom: 12px;
    }
    .ai-section h6 {
        color: #4f46e5; font-weight: 700; font-size: 0.88rem;
        margin-bottom: 8px; padding-bottom: 6px;
        border-bottom: 1px solid #e0e7ff;
        text-transform: uppercase; letter-spacing: 0.04em;
    }
    .ai-section p { font-size: 0.93rem; color: #1e293b; line-height: 1.7; margin: 0; }
    .recognition-badge {
        display: inline-flex; align-items: center; gap: 8px;
        background: linear-gradient(90deg, #4f46e5, #7c3aed);
        color: #fff; border-radius: 30px; padding: 6px 18px;
        font-size: 1rem; font-weight: 700; margin-bottom: 6px;
    }
    .style-badge {
        display: inline-block;
        background: linear-gradient(90deg, #0891b2, #6366f1);
        color: #fff; border-radius: 20px;
        padding: 5px 16px; font-size: 0.85rem; font-weight: 600;
    }
    .suggestion-item {
        display: flex; align-items: flex-start; gap: 10px;
        padding: 9px 0; border-bottom: 1px solid #f1f5f9;
        font-size: 0.9rem; color: #334155; line-height: 1.6;
    }
    .suggestion-item:last-child { border-bottom: none; padding-bottom: 0; }
    .suggestion-num {
        background: #6366f1; color: #fff; border-radius: 50%;
        width: 24px; height: 24px; display: flex;
        align-items: center; justify-content: center;
        font-size: 0.75rem; font-weight: 700; flex-shrink: 0; margin-top: 1px;
    }
    .palette-chip {
        display: inline-block; width: 38px; height: 38px;
        border-radius: 8px; border: 2px solid #e2e8f0;
        margin: 3px; vertical-align: middle; cursor: pointer;
        transition: transform 0.15s, border-color 0.15s;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }
    .palette-chip:hover { transform: scale(1.3); border-color: #6366f1; }
    #aiLoader {
        display: none; text-align: center;
        padding: 28px; color: #6366f1; font-weight: 600;
    }
    .spinner-dot {
        display: inline-block; width: 11px; height: 11px;
        border-radius: 50%; background: #6366f1; margin: 0 3px;
        animation: bounce 1.2s infinite ease-in-out;
    }
    .spinner-dot:nth-child(2) { animation-delay: 0.2s; }
    .spinner-dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes bounce {
        0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
        40%           { transform: scale(1.1); opacity: 1; }
    }
    .btn-ai {
        background: linear-gradient(90deg, #6366f1, #8b5cf6);
        color: #fff; border: none; border-radius: 8px;
        font-weight: 600; padding: 8px 22px; transition: opacity 0.2s;
    }
    .btn-ai:hover { opacity: 0.85; color: #fff; }
    .btn-generate {
        background: linear-gradient(90deg, #059669, #0891b2);
        color: #fff; border: none; border-radius: 8px;
        font-weight: 600; padding: 8px 22px; transition: opacity 0.2s;
        cursor: pointer;
    }
    .btn-generate:hover { opacity: 0.85; }
    .btn-generate:disabled { opacity: 0.5; cursor: not-allowed; }
    .card { border-radius: 16px; }
    .toolbar-label {
        font-size: 0.78rem; color: #64748b; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.05em;
    }
    .section-divider { border: none; border-top: 1px solid #e2e8f0; margin: 10px 0; }
    #generatedSection {
        background: linear-gradient(135deg, #f0fdf4, #ecfeff);
        border: 1.5px solid #6ee7b7;
        border-radius: 14px; padding: 20px; margin-top: 16px; display: none;
    }
    #generatedSection h5 { color: #059669; font-weight: 700; margin-bottom: 14px; }
    #generatedImageBox {
        text-align: center; padding: 10px;
        background: #fff; border-radius: 10px;
        border: 1px solid #d1fae5;
    }
    #generatedImageBox img {
        max-width: 100%; border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    }
    #genLoader {
        display: none; text-align: center;
        padding: 28px; color: #059669; font-weight: 600;
    }
    .gen-spinner {
        display: inline-block; width: 11px; height: 11px;
        border-radius: 50%; background: #059669; margin: 0 3px;
        animation: bounce 1.2s infinite ease-in-out;
    }
    .gen-spinner:nth-child(2) { animation-delay: 0.2s; }
    .gen-spinner:nth-child(3) { animation-delay: 0.4s; }
    #savedBadge {
        display: none;
        background: #059669; color: #fff;
        border-radius: 20px; padding: 4px 16px;
        font-size: 0.85rem; font-weight: 600; margin-top: 10px;
    }
</style>
</head>

